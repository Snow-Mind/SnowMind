# ============================================
# SnowMind Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ---- Frontend (apps/web/.env.local) ----
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_ZERODEV_PROJECT_ID=your_zerodev_project_id
NEXT_PUBLIC_PIMLICO_API_KEY=your_pimlico_key
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_API_KEY=your_backend_api_key
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CHAIN_ID=43113
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...  # from contract deployment
NEXT_PUBLIC_BENQI_POOL_ADDRESS=0x...  # MockBenqiPool on Fuji
NEXT_PUBLIC_EULER_VAULT_ADDRESS=0x...  # MockEulerVault on Fuji
NEXT_PUBLIC_IS_TESTNET=true

# ---- Backend (apps/backend/.env) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
PIMLICO_API_KEY=your_pimlico_api_key
ZERODEV_PROJECT_ID=your_zerodev_project_id
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
SESSION_KEY_ENCRYPTION_KEY=your_64_hex_chars_here  # openssl rand -hex 32
DEFILLAMA_BASE_URL=https://yields.llama.fi
JWT_SECRET=your_jwt_secret
BACKEND_API_KEY=your_backend_api_key
REGISTRY_CONTRACT_ADDRESS=0x...  # from contract deployment
BENQI_POOL_FUJI=0x...  # MockBenqiPool on Fuji
EULER_VAULT_FUJI=0x...  # MockEulerVault on Fuji
IS_TESTNET=true
REBALANCE_CHECK_INTERVAL=300  # 5 min on testnet (faster for demo)
MAX_PROTOCOL_ALLOCATION=0.60
MIN_REBALANCE_THRESHOLD=0.05
MIN_BALANCE_USD=5000

# ---- Contracts (contracts/.env) ----
DEPLOYER_PRIVATE_KEY=0x...  # Fuji deployer key (prefixed with 0x)
SNOWTRACE_API_KEY=your_snowtrace_api_key
