# SnowMind Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────────────
APP_NAME=SnowMind API
API_V1_PREFIX=/api/v1
DEBUG=true
IS_TESTNET=true

# ── CORS (JSON array of allowed origins) ─────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Blockchain ───────────────────────────────────────────────
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113
PIMLICO_API_KEY=
ZERODEV_PROJECT_ID=

# ── Deployed Contracts (Fuji) ────────────────────────────────
REGISTRY_CONTRACT_ADDRESS=
AAVE_V3_POOL=0x1775ECC8362dB6CaB0c7A9C0957cF656A5276c29
BENQI_POOL=
EULER_VAULT=
USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
ENTRYPOINT_V07=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import os; print(os.urandom(32).hex())"
SESSION_KEY_ENCRYPTION_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
BACKEND_API_KEY=

# ── Optimizer ────────────────────────────────────────────────
REBALANCE_CHECK_INTERVAL=1800
MAX_PROTOCOL_ALLOCATION=0.60
MIN_REBALANCE_THRESHOLD=0.05
MIN_BALANCE_USD=5000.0
MAX_APY_SANITY_BOUND=0.25
TWAP_WINDOW_MINUTES=15
MIN_REBALANCE_INTERVAL_HOURS=6

# ── Cross-validation / Oracle ────────────────────────────────
DEFILLAMA_BASE_URL=https://yields.llama.fi
RATE_DIVERGENCE_THRESHOLD=0.02
