# SnowMind Backend — Environment Variables (Mainnet Production)
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────────────
APP_NAME=SnowMind API
API_V1_PREFIX=/api/v1
DEBUG=false

# ── CORS (JSON array of allowed origins) ─────────────────────
ALLOWED_ORIGINS=["https://www.snowmind.xyz","https://snowmind.xyz"]
# Optional regex for preview/local domains (leave empty to use defaults)
ALLOWED_ORIGIN_REGEX=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Blockchain (Avalanche Mainnet) ───────────────────────────
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43114
PIMLICO_API_KEY=
ZERODEV_PROJECT_ID=

# ── Deployed Contracts (Mainnet) ─────────────────────────────
REGISTRY_CONTRACT_ADDRESS=
AAVE_V3_POOL=0x794a61358D6845594F94dc1DB02A252b5b4814aD
BENQI_QIUSDC=0xB715808a78F6041E46d61Cb123C9B4A27056AE9C
SPARK_SPUSDC=0x28B3a8fb53B741A8Fd78c0fb9A6B2393d896a43d
EULER_VAULT=0x37ca03aD51B8ff79aAD35FadaCBA4CEDF0C3e74e
SILO_SAVUSD_VAULT=0x606fe9a70338e798a292CA22C1F28C829F24048E
SILO_SUSDP_VAULT=0x8ad697a333569ca6f04c8c063e9807747ef169c1
SILO_GAMI_USDC_VAULT=0x1F0570a081FeE0e4dF6eAC470f9d2D53CDEDa1c5
FOLKS_SPOKE_COMMON=0xc03094C4690F3844EA17ef5272Bf6376e0CF2AC6
FOLKS_SPOKE_USDC=0xcD68014c002184707eaE7218516cB0762A44fDDF
FOLKS_HUB=0xb39c03297E87032fF69f4D42A6698e4c4A934449
FOLKS_MESSAGE_MANAGER=0xFc828C500c90E63134B2B73537cC6cADfF4Ce695
FOLKS_ACCOUNT_MANAGER=0x12Db9758c4D9902334C523b94e436258EB54156f
FOLKS_LOAN_MANAGER=0xF4c542518320F09943C35Db6773b2f9FeB2F847e
FOLKS_USDC_HUB_POOL=0x88f15e36308ED060d8543DA8E2a5dA0810Efded2
FOLKS_HUB_CHAIN_ID=100
FOLKS_USDC_POOL_ID=1
FOLKS_USDC_LOAN_TYPE_ID=2
FOLKS_ACCOUNT_NONCE=1
FOLKS_LOAN_NONCE=1
FOLKS_ACCOUNT_NONCE_SCAN_MAX=128
FOLKS_LOAN_NONCE_SCAN_MAX=8
FOLKS_ROUTE_RESOLVE_TIMEOUT_SECONDS=6.5
USDC_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E
ENTRYPOINT_V07=0x0000000071727De22E5E9d8BAf0edAc6f37da032
TREASURY_ADDRESS=

# ── Security ─────────────────────────────────────────────────
# Production KMS mode: AWS KMS only (used by boto3 in backend runtime).
# If you are not using AWS KMS, leave KMS_KEY_ID empty and set
# SESSION_KEY_ENCRYPTION_KEY to a random 64-hex (32-byte) key.
KMS_KEY_ID=
# Required for AWS KMS mode
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional temporary credentials for AWS KMS mode
AWS_SESSION_TOKEN=
# If KMS_KEY_ID is empty, set a random 64-hex (32-byte) value.
# Required in production when KMS is not configured.
SESSION_KEY_ENCRYPTION_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
# Service-to-service only. Never expose this in frontend env vars.
BACKEND_API_KEY=

# ── Privy auth (backend JWT verification) ───────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── Optimizer ────────────────────────────────────────────────
REBALANCE_CHECK_INTERVAL=14400
MAX_PROTOCOL_ALLOCATION=0.60
MIN_REBALANCE_THRESHOLD=0.05
MIN_BALANCE_USD=0.0
MAX_APY_SANITY_BOUND=0.25
TWAP_WINDOW_MINUTES=15
# Legacy knob (hours). Keep aligned with 6-minute cadence.
MIN_REBALANCE_INTERVAL_HOURS=0.1
MIN_PROTOCOL_TVL_USD=100000.0
BASE_LAYER_PROTOCOL_ID=aave_v3
MAX_SINGLE_EXPOSURE_PCT=0.40
BASE_BEAT_MARGIN=0.005
GAS_COST_ESTIMATE_USD=0.008
MAX_TOTAL_PLATFORM_DEPOSIT_USD=50000.0
PROFIT_FEE_PCT=0.10

# ── Execution Service (canonical: apps/execution) ────────────
# Local default can point to whichever execution service you run, but production
# should point to the dedicated apps/execution deployment URL.
EXECUTION_SERVICE_URL=http://localhost:3001
INTERNAL_SERVICE_KEY=
INTERNAL_REQUEST_TTL_SECONDS=300

# ── Cross-validation / Oracle ────────────────────────────────
DEFILLAMA_BASE_URL=https://yields.llama.fi
RATE_DIVERGENCE_THRESHOLD=0.02

# ── Monitoring / Observability ───────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PAYMASTER_LOW_BALANCE_AVAX=10.0

# ── API cache knobs (short TTL reduces duplicate polling load) ─────────────
PORTFOLIO_CACHE_TTL_SECONDS=8
OPTIMIZER_RATES_CACHE_TTL_SECONDS=20
APY_TIMESERIES_CACHE_TTL_SECONDS=60
RATE_FETCH_TIMEOUT_SECONDS=4.0
PROTOCOL_BALANCE_READ_TIMEOUT_SECONDS=8.0
TIMESERIES_LIVE_RATE_TIMEOUT_SECONDS=3.5
RISK_SCORE_MAX_AGE_HOURS=30

# ── AI Assistant (Gemini) ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_SECONDS=20
ASSISTANT_MAX_HISTORY_MESSAGES=20
