# SnowMind Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# Privy (auth + embedded wallets)
NEXT_PUBLIC_PRIVY_APP_ID=

# ZeroDev (smart account SDK)
NEXT_PUBLIC_ZERODEV_PROJECT_ID=

# Pimlico (ERC-4337 bundler + paymaster)
NEXT_PUBLIC_PIMLICO_API_KEY=

# Avalanche RPC (mainnet)
NEXT_PUBLIC_AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# Optional comma-separated fallback RPCs (used for tx confirmation retries)
NEXT_PUBLIC_AVALANCHE_RPC_URLS=https://api.avax.network/ext/bc/C/rpc,https://rpc.ankr.com/avalanche

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# Server-side proxy target for /api/* rewrites (useful in production).
# Must be the backend service origin, never app.snowmind.xyz (prevents 508 loops).
BACKEND_URL=http://localhost:8000
# Optional comma-separated browser fallback origins (used on DNS/network failure)
# NEXT_PUBLIC_BACKEND_FALLBACK_URLS=https://snowmindbackend-production-10ed.up.railway.app

# Chain ID: 43114 = Avalanche C-Chain mainnet
NEXT_PUBLIC_CHAIN_ID=43114

# Deployed contract addresses (override per environment)
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD
NEXT_PUBLIC_BENQI_POOL_ADDRESS=0xB715808a78F6041E46d61Cb123C9B4A27056AE9C
