# SnowMind Execution Service — Environment Variables
# Copy to .env in this folder for local runs.

# Required
ZERODEV_PROJECT_ID=
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# Optional comma-separated fallback RPCs
AVALANCHE_RPC_URLS=https://api.avax.network/ext/bc/C/rpc,https://rpc.ankr.com/avalanche
# Optional request origin sent to ZeroDev allowlist checks
ZERODEV_REQUEST_ORIGIN=https://app.snowmind.xyz
INTERNAL_SERVICE_KEY=

# Optional infra
PORT=3001
BUNDLER_RPC_URL=
PAYMASTER_RPC_URL=
EXECUTION_TIMEOUT_MS=60000
MAX_CONCURRENT_OPS=2

# Request auth replay guard
INTERNAL_REQUEST_TTL_SECONDS=300
# memory | supabase
NONCE_STORE_MODE=supabase
# When true and NONCE_STORE_MODE=supabase, boot fails if Supabase nonce store is unavailable.
NONCE_STORE_STRICT=true
NONCE_STORE_TABLE=internal_request_nonces

# Required when NONCE_STORE_MODE=supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Note: KMS_KEY_ID and SESSION_KEY_ENCRYPTION_KEY are backend-only settings.
